{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.json",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "fonts-and-icons",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(eot|svg|cur|jpg|png|webp|gif|otf|ttf|woff|woff2|ani)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "exercises-data",
      "urls": [
        "/data/exercises/**",
        "/data/all-exercises.json",
        "/data/learning-paths/**"
      ],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "30d",
        "strategy": "performance"
      }
    },
    {
      "name": "phase2-content",
      "urls": [
        "/data/grammar-lessons/**",
        "/data/reading/**",
        "/data/writing/**",
        "/data/listening/**"
      ],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "30d",
        "strategy": "performance"
      }
    },
    {
      "name": "vietnamese-seo-config",
      "urls": [
        "/vietnamese-seo-config.json"
      ],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "7d",
        "strategy": "performance"
      }
    },
    {
      "name": "api-cache-freshness",
      "urls": [
        "/api/**"
      ],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s",
        "strategy": "freshness"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**"
  ]
}
